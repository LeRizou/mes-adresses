# ─────────────────────────────────────────────────────────────────
#  .env.example — Template des variables d'environnement
#  ─────────────────────────────────────────────────────────────────
#  Ce fichier est committé dans le repo GitHub. Il ne contient
#  JAMAIS de valeurs réelles.
#
#  POUR DÉMARRER :
#    1. Copier ce fichier : cp .env.example .env
#    2. Remplir ADRESSES_API_URL et ADRESSES_API_KEY dans .env
#    3. Le fichier .env est dans .gitignore — il ne sera jamais committé
#
#  ADRESSES_API_URL :
#    URL de déploiement de votre Google Apps Script.
#    Récupérer dans GAS : Déployer → Gérer les déploiements → URL de l'app Web.
#    Format : https://script.google.com/macros/s/<ID>/exec
#
#  ADRESSES_API_KEY :
#    Valeur de la propriété "INTERNAL_API_KEY" définie dans PropertiesService GAS.
#    GAS : Extensions → Apps Script → Projet → Propriétés du script.
#    Cette clé est partagée entre le front et le GAS. Ne pas la réutiliser ailleurs.
#
#  SECURITE :
#    Ces valeurs sont injectées dans le bundle JS par Mes Adresses au moment du build.
#    Elles seront lisibles dans le bundle de production via DevTools.
#    Pour une protection maximale, utiliser un proxy serverless cote serveur.
#    Pour un usage personnel non critique, ce niveau de protection est suffisant.
# ─────────────────────────────────────────────────────────────────

ADRESSES_API_URL=https://script.google.com/macros/s/VOTRE_ID_DEPLOIEMENT/exec
ADRESSES_API_KEY=VOTRE_INTERNAL_API_KEY
